{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "updater:default",
    "process:allow-restart",
    "log:default"
  ]
}
